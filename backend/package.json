{
  "name": "travel-share-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "build": "prisma generate",
    "start": "prisma generate && prisma migrate deploy && node src/index.js",
    "postinstall": "node ../scripts/postinstall-sharp.cjs || true",
    "test:e2e": "vitest run tests/e2e",
    "db:seed:e2e": "node prisma/seed-e2e.js",
    "stripe:sync-products": "node scripts/sync-stripe-products.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "worker:uploads": "RUN_WORKER=true node scripts/upload-retry-worker.mjs",
    "seed:platform-settings": "node scripts/seed-platform-settings.mjs",
    "cleanup:guests": "node scripts/cleanup-expired-guests.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.17.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exifr": "^7.0.0",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "form-data": "4.0.6",
    "jsonwebtoken": "^9.0.2",
    "mkdirp": "^1.0.4",
    "multer": "2.2.0",
    "nanoid": "^5.0.7",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.5",
    "xtend": "^4.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "ioredis": "^5.3.2",
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0",
    "rate-limit-redis": "^2.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "form-data": "4.0.6"
  }
}
