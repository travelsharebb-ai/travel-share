generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  tourist
  admin
  platform_admin
  organizer
  guest
}

enum UploadStatus {
  pending
  approved
  rejected
  reported
}

enum FileType {
  image
  video
}

enum QrMode {
  open
  approval_required
  trusted
  time_limited
  family_safe
  paused
  expired
  revoked
}

enum AdMediaType {
  image
  video
}

enum EventStatus {
  draft
  live
  ended
  archived
}

enum EventVisibility {
  public
  private
  unlisted
}

enum CrowdStatus {
  low
  moderate
  high
}

enum LocationVisibility {
  exact
  approximate
  hidden
}

enum StoreItemType {
  image_skin
  photo_frame
  album_theme
  event_theme
  download_asset
  premium_qr
  branded_page
  ad_free
}

enum AdPlacement {
  global
  tourist
  event
  guest
  map
  upload_success
}

enum PaymentProvider {
  stripe
  paypal
}

enum PaymentStatus {
  pending
  paid
  canceled
  failed
}

model User {
  id                  String                 @id @default(cuid())
  name                String
  email               String                 @unique
  passwordHash        String
  role                UserRole               @default(tourist)
  trips               Trip[]
  moderationLogs      AdminModerationLog[]   @relation("AdminLogs")
  emailLogs           EmailNotificationLog[]
  downloadAuditLogs   DownloadAuditLog[]
  ads                 InternalAd[]           @relation("AdCreator")
  passwordResetTokens PasswordResetToken[]
  organizedEvents     Event[]                @relation("OrganizerEvents")
  guestSessions       GuestSession[]         @relation("ClaimedGuestSessions")
  purchases           UserPurchase[]
  paymentTransactions PaymentTransaction[]
  activeStoreItemId   String?
  activeStoreItem     PurchaseItem?          @relation("ActiveStoreItem", fields: [activeStoreItemId], references: [id], onDelete: SetNull)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([activeStoreItemId])
}

model Trip {
  id                        String             @id @default(cuid())
  userId                    String?
  user                      User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSessionId            String?
  guestSession              GuestSession?      @relation("GuestCreatedTrips", fields: [guestSessionId], references: [id], onDelete: SetNull)
  title                     String
  destination               String
  startDate                 DateTime?
  endDate                   DateTime?
  qrToken                   String             @unique
  qrActive                  Boolean            @default(true)
  qrExpiresAt               DateTime?
  qrMode                    QrMode             @default(open)
  uploads                   Upload[]
  shareLinks                ShareLink[]
  blockedUploaders          BlockedUploader[]
  chapters                  TripChapter[]
  defaultLocationVisibility LocationVisibility @default(approximate)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([userId])
  @@index([guestSessionId])
}

model TripChapter {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title     String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId, createdAt])
}

model Upload {
  id                     String                 @id @default(cuid())
  tripId                 String?
  trip                   Trip?                  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  eventId                String?
  event                  Event?                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  zoneId                 String?
  zone                   MapZone?               @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  guestSessionId         String?
  guestSession           GuestSession?          @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  downloadPurchaseItemId String?
  downloadPurchaseItem   PurchaseItem?          @relation("DownloadPurchaseItem", fields: [downloadPurchaseItemId], references: [id], onDelete: SetNull)
  uploaderAnonId         String
  uploaderFingerprint    String
  caption                String?
  fileUrl                String
  filePublicId           String
  fileType               FileType
  status                 UploadStatus           @default(pending)
  latitude               Float?
  longitude              Float?
  approximateLatitude    Float?
  approximateLongitude   Float?
  locationName           String?
  region                 String?
  locationVisibility     LocationVisibility     @default(approximate)
  aiFlagged              Boolean                @default(false)
  moderationProvider     String?
  moderationStatus       String?
  moderationLabels       Json?
  reportReason           String?
  createdAt              DateTime               @default(now())
  approvedAt             DateTime?
  rejectedAt             DateTime?
  moderationLogs         AdminModerationLog[]
  emailLogs              EmailNotificationLog[]
  downloadAuditLogs      DownloadAuditLog[]

  @@index([tripId, status])
  @@index([eventId, status])
  @@index([zoneId])
  @@index([guestSessionId])
  @@index([downloadPurchaseItemId])
  @@index([uploaderFingerprint])
}

model ShareLink {
  id        String   @id @default(cuid())
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  token     String   @unique
  pinHash   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlockedUploader {
  id                  String   @id @default(cuid())
  tripId              String
  trip                Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  uploaderFingerprint String
  reason              String?
  createdAt           DateTime @default(now())

  @@unique([tripId, uploaderFingerprint])
}

model AdminModerationLog {
  id        String   @id @default(cuid())
  uploadId  String
  upload    Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  adminId   String
  admin     User     @relation("AdminLogs", fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  notes     String?
  createdAt DateTime @default(now())
}

model EmailNotificationLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  uploadId     String?
  upload       Upload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  toEmail      String
  template     String
  subject      String
  provider     String
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([uploadId])
}

model InternalAd {
  id             String      @id @default(cuid())
  title          String
  description    String?
  mediaUrl       String
  mediaType      AdMediaType
  linkUrl        String?
  active         Boolean     @default(true)
  priority       Int         @default(0)
  displaySeconds Int         @default(12)
  placement      AdPlacement @default(global)
  startsAt       DateTime?
  endsAt         DateTime?
  createdById    String?
  createdBy      User?       @relation("AdCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([active, priority])
  @@index([startsAt, endsAt])
}

model GuestSession {
  id                String   @id @default(cuid())
  token             String   @unique
  deviceFingerprint String
  scopeType         String
  scopeId           String
  expiresAt         DateTime
  claimedById       String?
  claimedBy         User?    @relation("ClaimedGuestSessions", fields: [claimedById], references: [id], onDelete: SetNull)
  uploads           Upload[]
  createdTrips      Trip[]   @relation("GuestCreatedTrips")
  createdEvents     Event[]  @relation("GuestCreatedEvents")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([scopeType, scopeId])
  @@index([expiresAt])
  @@index([claimedById])
}

model Event {
  id             String          @id @default(cuid())
  organizerId    String?
  organizer      User?           @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: SetNull)
  guestSessionId String?
  guestSession   GuestSession?   @relation("GuestCreatedEvents", fields: [guestSessionId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  category       String?
  location       String?
  latitude       Float?
  longitude      Float?
  startDate      DateTime
  endDate        DateTime?
  visibility     EventVisibility @default(public)
  status         EventStatus     @default(draft)
  coverImageUrl  String?
  qrToken        String          @unique
  uploads        Upload[]
  maps           EventMap[]
  zones          MapZone[]
  shareLinks      ShareLink[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizerId])
  @@index([guestSessionId])
  @@index([status, visibility])
  @@index([startDate])
}

model EventMap {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  mapType     String   @default("image")
  imageUrl    String?
  mapboxStyle String?
  centerLat   Float?
  centerLng   Float?
  zoom        Float?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId, active])
}

model MapZone {
  id           String      @id @default(cuid())
  eventId      String
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  type         String
  description  String?
  x            Float?
  y            Float?
  latitude     Float?
  longitude    Float?
  shape        Json?
  crowdStatus  CrowdStatus @default(low)
  qrToken      String      @unique
  displayOrder Int         @default(0)
  uploads      Upload[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([eventId])
  @@index([crowdStatus])
}

model PurchaseItem {
  id                  String               @id @default(cuid())
  name                String
  description         String?
  type                StoreItemType
  priceCents          Int                  @default(0)
  previewUrl          String?
  active              Boolean              @default(true)
  metadata            Json?
  purchases           UserPurchase[]
  activeForUsers      User[]               @relation("ActiveStoreItem")
  paymentTransactions PaymentTransaction[]
  downloadableUploads Upload[]             @relation("DownloadPurchaseItem")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([active, type])
}

model UserPurchase {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      PurchaseItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  status    String       @default("owned")
  createdAt DateTime     @default(now())

  @@unique([userId, itemId])
  @@index([userId])
}

model DownloadAuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploadId  String
  upload    Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  success   Boolean  @default(false)
  reason    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([uploadId])
}

model PaymentTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId      String
  item        PurchaseItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  provider    PaymentProvider
  status      PaymentStatus   @default(pending)
  amountCents Int
  currency    String          @default("usd")
  providerRef String?
  checkoutUrl String?
  rawResponse Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([provider, providerRef])
  @@index([status])
}

model PlatformSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}
