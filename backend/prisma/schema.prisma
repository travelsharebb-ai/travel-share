generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  tourist
  admin
  platform_admin
  organizer
  guest
}

enum UploadStatus {
  pending
  approved
  rejected
  reported
}

enum FileType {
  image
  video
}

enum QrMode {
  open
  approval_required
  trusted
  time_limited
  family_safe
  paused
  expired
  revoked
}

enum AdMediaType {
  image
  video
}

enum EventStatus {
  draft
  live
  ended
  archived
}

enum EventVisibility {
  public
  private
  unlisted
}

enum CrowdStatus {
  low
  moderate
  high
}

enum LocationVisibility {
  exact
  approximate
  hidden
}

enum StoreItemType {
  image_skin
  photo_frame
  album_theme
  event_theme
  download_asset
  premium_qr
  branded_page
  ad_free
}

enum AdPlacement {
  global
  tourist
  event
  guest
  map
  upload_success
}

enum PaymentProvider {
  stripe
  paypal
}

enum PaymentStatus {
  pending
  paid
  canceled
  failed
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(tourist)

  activeStoreItemId String?
  activeStoreItem   PurchaseItem? @relation("ActiveStoreItem", fields: [activeStoreItemId], references: [id], onDelete: SetNull)

  trips                Trip[]
  organizedEvents      Event[]                @relation("OrganizerEvents")
  claimedGuestSessions GuestSession[]         @relation("ClaimedGuestSessions")
  purchases            UserPurchase[]
  skinUnlocks          UserSkinUnlock[]
  paymentTransactions  PaymentTransaction[]
  preferences          UserPreference?
  locations            Location[]
  moderationLogs       AdminModerationLog[]   @relation("AdminModerationLogs")
  emailLogs            EmailNotificationLog[]
  downloadAuditLogs    DownloadAuditLog[]
  ads                  InternalAd[]           @relation("AdCreator")
  passwordResetTokens  PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activeStoreItemId])
}

model UserPreference {
  id                        String             @id @default(cuid())
  userId                    String             @unique
  user                      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultLocationVisibility LocationVisibility @default(approximate)
  emailNotifications        Boolean            @default(true)
  uploadAlerts              Boolean            @default(true)
  promotionalEmails         Boolean            @default(false)
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt
}

model GuestSession {
  id                String   @id @default(cuid())
  token             String   @unique
  deviceFingerprint String?
  scopeType         String?
  scopeId           String?
  expiresAt         DateTime
  claimedById       String?
  claimedBy         User?    @relation("ClaimedGuestSessions", fields: [claimedById], references: [id], onDelete: SetNull)
  uploads           Upload[]
  trips             Trip[]
  events            Event[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([scopeType, scopeId])
  @@index([expiresAt])
  @@index([claimedById])
}

model Trip {
  id                        String             @id @default(cuid())
  userId                    String?
  user                      User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestSessionId            String?
  guestSession              GuestSession?      @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  title                     String
  destination               String
  startDate                 DateTime?
  endDate                   DateTime?
  qrToken                   String             @unique
  qrActive                  Boolean            @default(true)
  qrExpiresAt               DateTime?
  qrMode                    QrMode             @default(open)
  defaultLocationVisibility LocationVisibility @default(approximate)
  uploads                   Upload[]
  shareLinks                ShareLink[]
  chapters                  TripChapter[]
  blockedUploaders          BlockedUploader[]
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  @@index([userId])
  @@index([guestSessionId])
}

model TripChapter {
  id        String   @id @default(cuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title     String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
}

model Event {
  id             String          @id @default(cuid())
  organizerId    String?
  organizer      User?           @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: SetNull)
  guestSessionId String?
  guestSession   GuestSession?   @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  category       String?
  location       String?
  latitude       Float?
  longitude      Float?
  startDate      DateTime
  endDate        DateTime?
  visibility     EventVisibility @default(public)
  status         EventStatus     @default(draft)
  coverImageUrl  String?
  qrToken        String          @unique
  maps           EventMap[]
  zones          MapZone[]
  uploads        Upload[]
  shareLinks     ShareLink[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizerId])
  @@index([guestSessionId])
  @@index([status, visibility])
  @@index([startDate])
}

model EventMap {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title       String
  mapType     String   @default("image")
  imageUrl    String?
  mapboxStyle String?
  centerLat   Float?
  centerLng   Float?
  zoom        Float?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId, active])
}

model MapZone {
  id           String      @id @default(cuid())
  eventId      String
  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  type         String
  description  String?
  x            Float?
  y            Float?
  latitude     Float?
  longitude    Float?
  shape        Json?
  crowdStatus  CrowdStatus @default(low)
  qrToken      String      @unique
  displayOrder Int         @default(0)
  uploads      Upload[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([eventId])
  @@index([crowdStatus])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  latitude  Float?
  longitude Float?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  uploads   Upload[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Upload {
  id                     String                 @id @default(cuid())
  tripId                 String?
  trip                   Trip?                  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  eventId                String?
  event                  Event?                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  zoneId                 String?
  zone                   MapZone?               @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  locationId             String?
  location               Location?              @relation(fields: [locationId], references: [id], onDelete: SetNull)
  guestSessionId         String?
  guestSession           GuestSession?          @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  skinId                 String?
  skin                   PurchaseItem?          @relation("UploadSkin", fields: [skinId], references: [id], onDelete: SetNull)
  downloadPurchaseItemId String?
  downloadPurchaseItem   PurchaseItem?          @relation("UploadDownloadItem", fields: [downloadPurchaseItemId], references: [id], onDelete: SetNull)
  uploaderAnonId         String
  uploaderFingerprint    String?
  caption                String?
  fileUrl                String
  filePublicId           String
  fileType               FileType
  status                 UploadStatus           @default(pending)
  aiFlagged              Boolean                @default(false)
  moderationProvider     String?
  moderationStatus       String?
  moderationLabels       Json?
  reportReason           String?
  latitude               Float?
  longitude              Float?
  approximateLatitude    Float?
  approximateLongitude   Float?
  locationName           String?
  region                 String?
  locationVisibility     LocationVisibility     @default(approximate)
  uploadState            UploadState?
  moderationLogs         AdminModerationLog[]
  emailLogs              EmailNotificationLog[]
  downloadAuditLogs      DownloadAuditLog[]
  createdAt              DateTime               @default(now())
  approvedAt             DateTime?
  rejectedAt             DateTime?

  @@index([tripId, status])
  @@index([eventId, status])
  @@index([zoneId])
  @@index([guestSessionId])
  @@index([locationId])
  @@index([uploaderFingerprint])
  @@index([downloadPurchaseItemId])
}

model UploadState {
  id              String           @id @default(cuid())
  idempotencyKey  String           @unique
  status          String
  reservedToken   String?          @unique
  filePublicId    String?
  storageKey      String?
  storageProvider String?
  entityId        String
  type            String
  fingerprint     String?
  uploadId        String?          @unique
  upload          Upload?          @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  uploadRetryJobs UploadRetryJob[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model UploadRetryJob {
  id            String      @id @default(cuid())
  uploadStateId String
  uploadState   UploadState @relation(fields: [uploadStateId], references: [id], onDelete: Cascade)
  filePublicId  String
  attempts      Int         @default(0)
  lastError     String?
  nextAttemptAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([uploadStateId])
  @@index([nextAttemptAt])
}

model ShareLink {
  id        String   @id @default(cuid())
  tripId    String?
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  eventId   String?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  token     String   @unique
  pinHash   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tripId])
  @@index([eventId])
}

model BlockedUploader {
  id                  String   @id @default(cuid())
  tripId              String
  trip                Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  uploaderFingerprint String
  reason              String?
  createdAt           DateTime @default(now())

  @@unique([tripId, uploaderFingerprint])
}

model AdminModerationLog {
  id        String   @id @default(cuid())
  uploadId  String
  upload    Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  adminId   String
  admin     User     @relation("AdminModerationLogs", fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  notes     String?
  createdAt DateTime @default(now())

  @@index([uploadId])
  @@index([adminId])
}

model EmailNotificationLog {
  id           String   @id @default(cuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  uploadId     String?
  upload       Upload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  toEmail      String?
  template     String
  subject      String
  provider     String?
  status       String
  errorMessage String?
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([uploadId])
  @@index([template])
}

model DownloadAuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  uploadId  String?
  upload    Upload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  success   Boolean  @default(false)
  reason    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([uploadId])
}

model InternalAd {
  id             String      @id @default(cuid())
  createdById    String?
  creator        User?       @relation("AdCreator", fields: [createdById], references: [id], onDelete: SetNull)
  title          String
  description    String?
  mediaUrl       String
  mediaType      AdMediaType
  linkUrl        String?
  active         Boolean     @default(true)
  priority       Int         @default(0)
  placement      AdPlacement @default(global)
  displaySeconds Int?
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([active, priority])
  @@index([startsAt, endsAt])
  @@index([createdById])
}

model PurchaseItem {
  id             String               @id @default(cuid())
  sku            String?              @unique
  name           String
  description    String?
  type           StoreItemType
  priceCents     Int                  @default(0)
  previewUrl     String?
  active         Boolean              @default(true)
  metadata       Json?
  purchases      UserPurchase[]
  skinUnlocks    UserSkinUnlock[]
  activeUsers    User[]               @relation("ActiveStoreItem")
  skinnedUploads Upload[]             @relation("UploadSkin")
  gatedUploads   Upload[]             @relation("UploadDownloadItem")
  transactions   PaymentTransaction[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([active, type])
}

model UserPurchase {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId    String
  item      PurchaseItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  status    String       @default("owned")
  createdAt DateTime     @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@index([itemId])
}

model UserSkinUnlock {
  id        String       @id
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skinId    String
  skin      PurchaseItem @relation(fields: [skinId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, skinId])
  @@index([userId])
  @@index([skinId])
}

model PaymentTransaction {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId      String
  item        PurchaseItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  provider    PaymentProvider
  status      PaymentStatus   @default(pending)
  amountCents Int
  providerRef String?
  checkoutUrl String?
  rawResponse Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([userId])
  @@index([itemId])
  @@index([providerRef])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
